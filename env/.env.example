# =============================================================================
# .env.example — config NÃO-secreta do deploy ACDG-BV. Copie p/ ../env/.env
# (gitignored). Secrets reais ficam em ${SECRETS_DIR} (file:), NUNCA aqui.
# =============================================================================

# Projeto / isolamento PROD vs DEV (ADR-012)
COMPOSE_PROJECT_NAME=acdg-bv

# Domínio (Cloudflare → Floating IP da VPS Magalu)
DOMAIN=acdg-bv.org.br
ACME_EMAIL=ops@acdg-bv.org.br

# Timezone Boa Vista (Roraima, UTC-4)
TZ=America/Boa_Vista

# Registry + tags das imagens ACDG (CI de cada serviço publica no GHCR)
REGISTRY=ghcr.io/acdgbrasil
WEB_TAG=latest
SC_TAG=latest        # social-care
PC_TAG=latest        # people-context
BI_TAG=latest        # analysis-bi

# Versões pinadas de imagens de plataforma
POSTGRES_TAG=16-alpine
NATS_TAG=2.10-alpine
CADDY_TAG=2.10-alpine
AUTHENTIK_TAG=2026.4
REDIS_TAG=7-alpine
VAULTWARDEN_TAG=1.32.7-alpine

# Caminhos no host (Block Storage NVMe montado em /data — ADR-009 §5)
SECRETS_DIR=/etc/acdg-secrets
DATA_DIR=/data

# Postgres (database-per-service; senhas via secrets file:)
POSTGRES_SUPERUSER=postgres

# OIDC (Authentik — IdP único do BV; ADR-027)
OIDC_ISSUER=https://auth.acdg-bv.org.br/application/o/acdg-bv/
OIDC_JWKS_URL=https://auth.acdg-bv.org.br/application/o/acdg-bv/jwks/
